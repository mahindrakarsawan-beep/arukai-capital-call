{
  "summary": "Capital Call Approval Workflow",
  "description": "Governs the lifecycle of a capital call package: receive → classify → review → approve → record decision",
  "value": {
    "modules": [
      {
        "id": "receive_package",
        "value": {
          "type": "script",
          "path": "f/scripts/receive_package",
          "input_transforms": {
            "package_id": {"type": "javascript", "expr": "flow_input.package_id"},
            "uploaded_by": {"type": "javascript", "expr": "flow_input.uploaded_by"}
          }
        },
        "summary": "Receive and register the capital call package"
      },
      {
        "id": "classify_document",
        "value": {
          "type": "script",
          "path": "f/scripts/classify_document",
          "input_transforms": {
            "package_id": {"type": "javascript", "expr": "flow_input.package_id"}
          }
        },
        "summary": "AI classification — extract fields and assess confidence"
      },
      {
        "id": "review_gate",
        "value": {
          "type": "identity"
        },
        "suspend": {
          "required_events": 1,
          "timeout": 604800,
          "resume_form": {
            "schema": {
              "type": "object",
              "properties": {
                "approved": {"type": "boolean", "description": "Whether the review passes"},
                "note": {"type": "string", "description": "Reviewer notes"}
              },
              "required": ["approved"]
            }
          }
        },
        "summary": "Human review gate — reviewer must claim and route"
      },
      {
        "id": "approval_gate",
        "value": {
          "type": "identity"
        },
        "suspend": {
          "required_events": 1,
          "timeout": 604800,
          "resume_form": {
            "schema": {
              "type": "object",
              "properties": {
                "approved": {"type": "boolean", "description": "Formal attestation decision"},
                "note": {"type": "string", "description": "Attestation notes"}
              },
              "required": ["approved"]
            }
          }
        },
        "summary": "Attestation gate — approver formally records decision"
      },
      {
        "id": "record_decision",
        "value": {
          "type": "script",
          "path": "f/scripts/record_decision",
          "input_transforms": {
            "package_id": {"type": "javascript", "expr": "flow_input.package_id"},
            "approved": {"type": "javascript", "expr": "resume.approved"},
            "note": {"type": "javascript", "expr": "resume.note || ''"}
          }
        },
        "summary": "Record the final decision in the audit trail"
      }
    ]
  },
  "schema": {
    "type": "object",
    "properties": {
      "package_id": {"type": "string", "description": "UUID of the capital call package"},
      "uploaded_by": {"type": "string", "description": "User ID who submitted the package"}
    },
    "required": ["package_id", "uploaded_by"]
  }
}
