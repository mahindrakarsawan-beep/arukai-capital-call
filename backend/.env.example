# Backend environment variables — copy to .env and fill in values.
# Never commit .env to version control.

# --- Database ---
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/capital_call

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8

# --- AI Providers (primary: Mistral, fallback: OpenAI) ---
MISTRAL_API_KEY=your-mistral-api-key
OPENAI_API_KEY=your-openai-api-key

# --- App ---
APP_ENV=development
APP_DOCS_ENABLED=true
