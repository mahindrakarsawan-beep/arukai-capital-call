# App
APP_ENV=development
DATABASE_URL=postgresql+psycopg://capital_call:capital_call@localhost:5432/capital_call
JWT_SECRET=change-me-to-a-long-random-string

# AI (Mistral primary, OpenAI dev-only fallback)
# GH Actions: set MISTRAL_API_KEY as a GitHub Actions secret (Settings > Secrets);
# also add to GCP Secret Manager as MISTRAL_API_KEY for Cloud Run injection.
MISTRAL_API_KEY=your-mistral-key
OPENAI_API_KEY=your-openai-key

# Encryption (plaintext if unset)
FIELD_ENCRYPTION_KEY=

# OIDC (501 if unset)
OIDC_ISSUER_URL=http://localhost:9000/application/o/capital-call/
OIDC_CLIENT_ID=capital-call-app
OIDC_CLIENT_SECRET=from-authentik
OIDC_REDIRECT_URI=http://localhost:3000/auth/callback

# Windmill (custom state machine if unset)
WINDMILL_BASE_URL=http://localhost:8100
# GH Actions: set WINDMILL_TOKEN as a GitHub Actions secret; also store in GCP Secret Manager.
WINDMILL_TOKEN=from-windmill

# Backups
# GH Actions: set BACKUP_GCS_BUCKET as a GitHub Actions repo-level variable (not a secret —
# bucket names are not sensitive).  Cloud Run deploy reads it via vars.BACKUP_GCS_BUCKET.
BACKUP_GCS_BUCKET=

# Authentik
AUTHENTIK_SECRET_KEY=change-me
